---
import Base from '../layouts/Base.astro';
import Terminal from '../components/Terminal.astro';
import CopyCommand from '../components/CopyCommand.astro';

const demoLines = [
  { type: 'cmd',  text: 'npx pterospeed@latest .' },
  { type: 'blank', text: '' },
  { type: 'ok',   text: '✔ Detected: Pterodactyl Panel' },
  { type: 'ok',   text: '✔ Root: /var/www/pterodactyl' },
  { type: 'dim',  text: 'Scanning build configuration...' },
  { type: 'blank', text: '' },
  { type: 'warn', text: '⚠ Filesystem cache missing  (high)' },
  { type: 'warn', text: '⚠ babel-loader cache missing  (high)' },
  { type: 'warn', text: '⚠ source-map-loader scans too wide  (medium)' },
  { type: 'warn', text: '⚠ TerserPlugin still in production path  (medium)' },
  { type: 'warn', text: '⚠ minimize: true always runs  (medium)' },
  { type: 'blank', text: '' },
  { type: 'dim',  text: '  Build Health: 20 / 100  Critical' },
  { type: 'dim',  text: '  ████████░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░░' },
];

const optimizeLines = [
  { type: 'cmd',   text: 'pterospeed optimize . --preset aggressive' },
  { type: 'blank', text: '' },
  { type: 'ok',   text: '✔ Applied 5 optimization(s).' },
  { type: 'dim',  text: '  - Switched webpack cache to filesystem.' },
  { type: 'dim',  text: '  - Enabled babel-loader disk cache.' },
  { type: 'dim',  text: '  - Excluded node_modules from source-map-loader.' },
  { type: 'dim',  text: '  - Replaced TerserPlugin with EsbuildPlugin.' },
  { type: 'dim',  text: '  - minimize: true → minimize: isProduction.' },
  { type: 'blank', text: '' },
  { type: 'green', text: '  › Production minification: ~3-4x faster' },
  { type: 'green', text: '  › Warm dev builds: ~5-10x faster' },
  { type: 'green', text: '  › Dev builds skip minification (~30-60s saved)' },
];

const opts = [
  { name: 'Webpack filesystem cache', preset: 'safe',       gain: 'Warm builds 5–10× faster' },
  { name: 'babel-loader disk cache',  preset: 'safe',       gain: 'Cold builds ~20–30% faster' },
  { name: 'Scope source-map-loader',  preset: 'safe',       gain: 'Skips node_modules map parsing' },
  { name: 'Explicit CPU parallelism', preset: 'safe',       gain: 'Full core utilization' },
  { name: 'minimize: isProduction',   preset: 'safe',       gain: 'Dev skips minification (~30-60s)' },
  { name: 'EsbuildPlugin (prod)',      preset: 'aggressive', gain: 'Production minify 3–4× faster' },
];
---

<Base>
  <!-- NAV -->
  <nav class="flex items-center justify-between px-6 py-5 max-w-5xl mx-auto">
    <span class="text-[#00ff88] font-bold tracking-tight">pterospeed</span>
    <div class="flex items-center gap-6 text-sm text-[#555]">
      <a href="https://github.com/Molret/pterospeed" target="_blank" rel="noopener" class="hover:text-[#e2e2e2] transition-colors">GitHub</a>
      <a href="https://www.npmjs.com/package/pterospeed" target="_blank" rel="noopener" class="hover:text-[#e2e2e2] transition-colors">npm</a>
    </div>
  </nav>

  <!-- HERO -->
  <section class="max-w-5xl mx-auto px-6 pt-20 pb-16 text-center">
    <div class="inline-block bg-[#111] border border-[#1e1e1e] rounded-full px-4 py-1.5 text-xs text-[#555] mb-8">
      v0.1.1 — now on npm
    </div>
    <h1 class="text-4xl sm:text-6xl font-bold tracking-tight leading-tight mb-6">
      Your Pterodactyl build<br />
      <span class="text-[#00ff88]">in under 90 seconds.</span>
    </h1>
    <p class="text-[#555] text-lg max-w-xl mx-auto mb-10 leading-relaxed">
      pterospeed analyzes your webpack config, finds what's slowing it down,
      and fixes it — automatically, with a diff preview and backup before touching anything.
    </p>
    <div class="max-w-sm mx-auto mb-4">
      <CopyCommand command="npx pterospeed@latest ." />
    </div>
    <p class="text-xs text-[#333]">no install required · Node 20+</p>
  </section>

  <!-- PROBLEM -->
  <section class="max-w-5xl mx-auto px-6 py-16 border-t border-[#111]">
    <div class="grid md:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-xs text-[#555] uppercase tracking-widest mb-4">The problem</p>
        <h2 class="text-2xl font-bold mb-4 leading-snug">
          5 minutes every build.<br />
          <span class="text-[#555]">Every. Single. Time.</span>
        </h2>
        <p class="text-[#555] leading-relaxed mb-6">
          The default webpack config that ships with Pterodactyl Panel was written to work,
          not to be fast. Every build starts from zero and pays the full cost.
        </p>
        <div class="space-y-2 text-sm">
          {[
            'Memory-only webpack cache — lost after every process',
            'Babel re-transpiles unchanged files on every run',
            'TerserPlugin minifying even in development builds',
            'source-map-loader scanning all of node_modules',
          ].map(text => (
            <div class="flex items-center gap-3">
              <span class="text-red-400 shrink-0">✗</span>
              <span class="text-[#555]">{text}</span>
            </div>
          ))}
        </div>
      </div>
      <div class="bg-[#0d0d0d] border border-[#1e1e1e] rounded-lg p-6 font-mono text-sm">
        <p class="text-[#333] text-xs mb-4">$ yarn build:production</p>
        <p class="text-[#555]">webpack compiled successfully in</p>
        <p class="text-red-400 text-3xl font-bold my-3">352.41s</p>
        <div class="mt-5 pt-5 border-t border-[#1a1a1a]">
          <p class="text-[#333] text-xs mb-2">after pterospeed optimize --preset aggressive</p>
          <p class="text-[#00ff88] text-3xl font-bold">~78s</p>
          <p class="text-[#333] text-xs mt-1">same output · no code changes</p>
        </div>
      </div>
    </div>
  </section>

  <!-- DEMO -->
  <section class="max-w-5xl mx-auto px-6 py-16 border-t border-[#111]">
    <p class="text-xs text-[#555] uppercase tracking-widest mb-4">How it works</p>
    <h2 class="text-2xl font-bold mb-10">Two commands. Done.</h2>
    <div class="grid md:grid-cols-2 gap-6">
      <div>
        <p class="text-xs text-[#555] mb-3">1 — analyze your config</p>
        <Terminal lines={demoLines} title="pterospeed analyze" />
      </div>
      <div>
        <p class="text-xs text-[#555] mb-3">2 — apply the fixes</p>
        <Terminal lines={optimizeLines} title="pterospeed optimize" />
      </div>
    </div>
  </section>

  <!-- TABLE -->
  <section class="max-w-5xl mx-auto px-6 py-16 border-t border-[#111]">
    <p class="text-xs text-[#555] uppercase tracking-widest mb-4">Optimizations</p>
    <h2 class="text-2xl font-bold mb-8">What gets fixed</h2>
    <div class="overflow-x-auto">
      <table class="w-full text-sm border-collapse">
        <thead>
          <tr class="border-b border-[#1e1e1e]">
            <th class="text-left py-3 pr-8 text-[#555] font-normal">Optimization</th>
            <th class="text-left py-3 pr-8 text-[#555] font-normal">Preset</th>
            <th class="text-left py-3 text-[#555] font-normal">Expected gain</th>
          </tr>
        </thead>
        <tbody>
          {opts.map(opt => (
            <tr class="border-b border-[#0f0f0f] hover:bg-[#0d0d0d] transition-colors">
              <td class="py-3 pr-8 text-[#e2e2e2]">{opt.name}</td>
              <td class="py-3 pr-8">
                <span class={`text-xs px-2 py-0.5 rounded border ${opt.preset === 'safe' ? 'text-[#00ff88] border-[#00ff8830] bg-[#00ff8808]' : 'text-yellow-400 border-yellow-400/20 bg-yellow-400/5'}`}>
                  {opt.preset}
                </span>
              </td>
              <td class="py-3 text-[#555]">{opt.gain}</td>
            </tr>
          ))}
        </tbody>
      </table>
    </div>
    <p class="mt-4 text-xs text-[#333]">After aggressive preset: run <code class="text-[#444]">yarn install</code> in your panel to install esbuild-loader.</p>
  </section>

  <!-- COMMANDS -->
  <section class="max-w-5xl mx-auto px-6 py-16 border-t border-[#111]">
    <p class="text-xs text-[#555] uppercase tracking-widest mb-4">CLI</p>
    <h2 class="text-2xl font-bold mb-8">All commands</h2>
    <div class="space-y-0">
      {[
        { cmd: 'pterospeed analyze [path]',                   desc: 'Scan config and report score' },
        { cmd: 'pterospeed optimize [path]',                  desc: 'Diff → confirm → apply fixes' },
        { cmd: 'pterospeed optimize --auto',                  desc: 'Skip confirmation prompt' },
        { cmd: 'pterospeed optimize --dry',                   desc: 'Show diff only, write nothing' },
        { cmd: 'pterospeed optimize --preset aggressive',     desc: 'Also swap TerserPlugin → EsbuildPlugin' },
        { cmd: 'pterospeed benchmark [path]',                 desc: 'Measure cold / warm / production builds' },
        { cmd: 'pterospeed revert [path]',                    desc: 'Restore last backup' },
      ].map(({ cmd, desc }) => (
        <div class="flex flex-col sm:flex-row sm:gap-8 py-3 border-b border-[#0f0f0f] text-sm">
          <code class="text-[#00ff88] shrink-0 sm:w-80 mb-1 sm:mb-0">{cmd}</code>
          <span class="text-[#555]">{desc}</span>
        </div>
      ))}
    </div>
  </section>

  <!-- CTA -->
  <section class="max-w-5xl mx-auto px-6 py-24 border-t border-[#111] text-center">
    <h2 class="text-3xl font-bold mb-4">Stop waiting for builds.</h2>
    <p class="text-[#555] mb-10 text-lg">Run it right now — no install, no config, no risk. Backup created before touching anything.</p>
    <div class="max-w-sm mx-auto mb-8">
      <CopyCommand command="npx pterospeed@latest ." />
    </div>
    <a href="https://github.com/Molret/pterospeed" target="_blank" rel="noopener"
      class="inline-flex items-center gap-2 text-sm text-[#444] hover:text-[#00ff88] transition-colors">
      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="currentColor">
        <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
      </svg>
      ⭐ Star on GitHub
    </a>
  </section>

  <!-- FOOTER -->
  <footer class="border-t border-[#111] px-6 py-8 text-center text-xs text-[#2a2a2a]">
    <p>pterospeed — MIT — <a href="https://github.com/Molret" class="hover:text-[#555] transition-colors">Molret</a></p>
  </footer>
</Base>
