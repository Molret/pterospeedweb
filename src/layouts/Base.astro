---
interface Props {
  title?: string;
  description?: string;
}
const {
  title = 'pterospeed — faster Pterodactyl builds',
  description = 'Analyze, optimize, and audit your Pterodactyl Panel in one command. Cut build time from 5 minutes to under 90 seconds.',
} = Astro.props;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta name="twitter:card" content="summary" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap" rel="stylesheet" />
    <style is:global>
      @import "tailwindcss";

      @theme {
        --font-sans: "Inter", ui-sans-serif, system-ui, sans-serif;
        --font-mono: "JetBrains Mono", ui-monospace, monospace;
      }

      * { box-sizing: border-box; }

      html {
        background: #05050a;
        color: #e2e2e2;
        font-family: var(--font-sans);
        -webkit-font-smoothing: antialiased;
      }

      body {
        /* Dot grid background */
        background-image: radial-gradient(circle at 1px 1px, rgba(255,255,255,0.04) 1px, transparent 0);
        background-size: 32px 32px;
        background-color: #05050a;
      }

      ::selection { background: #00ff8825; color: #00ff88; }

      ::-webkit-scrollbar { width: 4px; }
      ::-webkit-scrollbar-track { background: #0a0a12; }
      ::-webkit-scrollbar-thumb { background: #1e1e2e; border-radius: 2px; }

      .glow-green { text-shadow: 0 0 40px rgba(0, 255, 136, 0.4); }
      .glow-card {
        box-shadow: 0 0 0 1px rgba(255,255,255,0.06), 0 4px 24px rgba(0,0,0,0.4);
      }
      .glow-card:hover {
        box-shadow: 0 0 0 1px rgba(0,255,136,0.15), 0 4px 32px rgba(0,255,136,0.06);
        transition: box-shadow 0.25s ease;
      }

      code, pre { font-family: var(--font-mono); }
    </style>
  </head>
  <body class="min-h-screen">
    <slot />
  </body>
</html>
